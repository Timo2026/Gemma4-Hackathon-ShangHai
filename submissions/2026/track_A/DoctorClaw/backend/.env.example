# Gemma 4 云端 API 配置
# 复制为 .env 后填入真实 Key：copy .env.example .env

# Skill Runtime — 病历结构化（31B Dense）
LLM_PROVIDER=gemma
LLM_BASE_URL=https://api.deepinfra.com/v1/openai
LLM_API_KEY=your-deepinfra-token
LLM_MODEL=google/gemma-4-31B-it
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_FALLBACK_TO_MOCK=true
LLM_DISABLE_THINKING=true
LLM_ENABLE_THINKING=false
LLM_STRUCTURED_OUTPUT_MODE=json_schema

# Agent Harness — 多轮工具编排（26B MoE）
AGENT_MODEL=google/gemma-4-26B-A4B-it
AGENT_BASE_URL=https://api.deepinfra.com/v1/openai
AGENT_API_KEY=your-deepinfra-token

# 可选：Web 搜索增强
WEB_SEARCH_API_KEY=

# MongoDB（HITL interrupt/resume 必需；未安装时自动回退 MemorySaver）
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=doctorclaw_agent
MONGODB_CHECKPOINT_COLLECTION=checkpoints

# Harness 服务
MEDICAL_API_BASE_URL=http://localhost:8000/api
MCP_HOST=127.0.0.1
MCP_PORT=8001
MCP_PATH=/mcp
AGENT_API_PORT=8090

# OpenSandbox（Phase 4 前留空，使用本地 FilesystemBackend 降级）
SANDBOX_DOMAIN=
