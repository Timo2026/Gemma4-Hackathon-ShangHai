# Cloudflare AI Gateway / OpenAI-compatible endpoint
CF_AIG_TOKEN=your-cloudflare-ai-gateway-token
CF_AIG_BASE_URL=https://gateway.ai.cloudflare.com/v1/bbd869342ef49cfea41170378427db5d/default/compat

# Model configuration
MODEL_NAME=google-ai-studio/gemini-2.5-flash
# Optional: set this only when Cloudflare should forward a separate provider key.
# MODEL_API_KEY=your-provider-api-key

# Google Gemini official OpenAI-compatible API
# CF_AIG_TOKEN=your-google-gemini-api-key
# CF_AIG_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# MODEL_NAME=gemini-2.5-flash

# Voice transcription for /api/audio/transcribe.
# If omitted, the endpoint falls back to OPENAI_API_KEY, MODEL_API_KEY, or CF_AIG_TOKEN.
TRANSCRIPTION_API_KEY=your-openai-or-compatible-api-key
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TRANSCRIPTION_BASE_URL=https://api.openai.com/v1

# Prompt mode: WEAK or STRONG
PROMPT_MODE=WEAK

# Optional server port
PORT=8080

# Optional on-device model artifact storage.
# /api/models dynamically lists every .litertlm/.task file under this bucket/prefix,
# so the APK can show newly uploaded models without being rebuilt.
CAREMIND_GCS_MODEL_BUCKET=caremind-498713-models
CAREMIND_GCS_MODEL_PREFIX=models
# Set to 0 only if you want to disable bucket scanning and use static model IDs.
CAREMIND_GCS_DYNAMIC_CATALOG=1
# redirect avoids Cloud Run large-response limits; proxy is only for small files/private networks.
CAREMIND_GCS_MODEL_DELIVERY=redirect

# ── External MCP Knowledge Sources（可选）──
# 未配置时不阻断流程，仅使用内置 KNOWLEDGE_DB
# DrugBank MCP for drug information / interactions
DRUGBANK_API_KEY=your_drugbank_api_key
# Future: PubChem, OpenFDA, etc.
# PUBCHEM_API_KEY=
# OPENFDA_API_KEY=
