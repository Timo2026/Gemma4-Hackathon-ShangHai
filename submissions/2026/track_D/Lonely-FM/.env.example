# Hume AI
HUME_API_KEY=
HUME_STREAM_URL=wss://api.hume.ai/v0/stream/models
HUME_TIMEOUT_SECONDS=8

# Google AI Studio (Gemma 4)
GEMMA_PROVIDER=local
GOOGLE_AI_API_KEY=
GEMMA_MODEL=gemma4:12b-mlx

# Local Gemma deployment
# LOCAL_GEMMA_PROVIDER=ollama for Ollama /api/chat
# LOCAL_GEMMA_PROVIDER=openai for LM Studio, vLLM, llama.cpp server, etc.
LOCAL_GEMMA_PROVIDER=ollama
LOCAL_GEMMA_BASE_URL=http://127.0.0.1:11434
LOCAL_GEMMA_API_KEY=

# Fish Audio TTS
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=

# Text-to-speech provider
# Use minimax for the emotional Mandarin demo. It automatically falls back to Google when no key is configured.
TTS_PROVIDER=minimax

# MiniMax Speech 2.8 emotional TTS
MINIMAX_API_KEY=
MINIMAX_TTS_ENDPOINT=https://api-uw.minimax.io/v1/t2a_v2
MINIMAX_TTS_STREAMING=false
MINIMAX_TTS_WS_ENDPOINT=wss://api.minimax.io/ws/v1/t2a_v2
MINIMAX_TTS_MODEL=speech-2.6-turbo
MINIMAX_TTS_VOICE_ID="Chinese (Mandarin)_Radio_Host"
MINIMAX_TTS_LANGUAGE_BOOST=Chinese
MINIMAX_TTS_SPEED=1.0
MINIMAX_TTS_VOLUME=1.0
MINIMAX_TTS_PITCH=0
MINIMAX_TTS_SAMPLE_RATE=24000
MINIMAX_TTS_BITRATE=64000
HYBRID_FIRST_CHUNK_TTS=false

GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-tts-service-account.json
GOOGLE_TTS_LANGUAGE=cmn-CN
GOOGLE_TTS_VOICE=cmn-CN-Chirp3-HD-Aoede
GOOGLE_TTS_SPEAKING_RATE=0.94
GOOGLE_TTS_PITCH=1.5

# OpenAI Whisper STT
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost/lonelyfm

# Supabase cross-device auth and memory
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Vite exposes only VITE_ variables to the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=http://127.0.0.1:8001
VITE_WS_BASE_URL=ws://127.0.0.1:8001

# App
SECRET_KEY=change-me
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://lonely-fm.vercel.app
DEMO_MODE=true
